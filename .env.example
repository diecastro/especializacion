# Inventarios 360 — Variables de entorno para conexión a Neon PostgreSQL
#
# Copia este archivo como .env y completa con tus credenciales reales.
# El archivo .env está ignorado por git — NUNCA lo versiones.
#
# Obtén estos valores desde el dashboard de Neon:
#   https://console.neon.tech → tu proyecto → Connection Details

PGHOST=ep-xxxx-xxxx.us-east-2.aws.neon.tech
PGDATABASE=neondb
PGUSER=neondb_owner
PGPASSWORD=your_password_here
PGSSLMODE=require
PGCHANNELBINDING=require
